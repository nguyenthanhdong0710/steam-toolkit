STEAM_REFRESH_TOKEN=
STEAM_ACCOUNT_NAME=
STEAM_PASSWORD=
# Optional: Steam Web API key (required for some WebAPI calls like GetPlayerBans)
# Get one at https://steamcommunity.com/dev/apikey and keep it secret.
STEAM_WEBAPI_KEY=
# Required to secure /api/cron/profile-theme. Vercel automatically sends this
# as an `Authorization: Bearer` header when invoking cron jobs, as long as
# this env var is also set in the Vercel project settings.
CRON_SECRET=

# NextAuth + auth-service (login, session, and password/passkey verification)
NEXTAUTH_SECRET=
AUTH_SERVICE_URL=
AUTH_SERVICE_API_KEY=
# Set to "true" to authenticate app login via the external auth-service
# (username/password + WebAuthn passkey/biometric). Leave unset (or anything
# other than "true") to authenticate directly against STEAM_ACCOUNT_NAME /
# STEAM_PASSWORD above instead — no biometric support in that mode.
USE_EXTERNAL_AUTH_SERVICE=
# Client-visible mirror of USE_EXTERNAL_AUTH_SERVICE — keep it in sync.
# Controls whether the login page offers "Login via Passkey" and whether a
# fresh password login attempts to register a passkey.
NEXT_PUBLIC_USE_EXTERNAL_AUTH_SERVICE=
NEXT_PUBLIC_BASE_URL=